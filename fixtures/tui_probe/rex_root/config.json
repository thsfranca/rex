{
  "version": 1,
  "daemon": {
    "socket_scope": "per_workspace",
    "ready_timeout_secs": 30,
    "idle_shutdown_secs": 0,
    "log_path": "daemon.log"
  },
  "sidecars": {
    "active": "stub",
    "required": false,
    "harness": "direct",
    "list": [
      {
        "name": "stub",
        "binary": "rex-sidecar-stub",
        "enabled": false,
        "socket": "sockets/sidecar.sock"
      }
    ]
  },
  "inference": {
    "runtime": "mock"
  },
  "agent": {
    "approvals_enabled": true
  },
  "cli": {
    "ui": {
      "sync_output": true
    }
  },
  "search": {
    "enabled": false
  }
}
