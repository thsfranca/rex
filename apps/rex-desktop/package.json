{
  "name": "rex-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Rex desktop shell (Electron) — loads apps/rex-web",
  "main": "src/main.cjs",
  "scripts": {
    "start": "electron .",
    "start:proof": "electron . -- --proof",
    "start:bury": "electron . -- --proof --bury",
    "compositor-proof": "node scripts/run-compositor-proof.mjs",
    "compositor-proof:bury-expect-fail": "node scripts/run-compositor-proof.mjs --bury --expect-fail"
  },
  "devDependencies": {
    "electron": "^36.4.0",
    "playwright": "^1.53.0",
    "pngjs": "^7.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
