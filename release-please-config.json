{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "extensions/rex-vscode": {
      "release-type": "node",
      "component": "rex-vscode",
      "changelog-path": "extensions/rex-vscode/CHANGELOG.md"
    }
  },
  "pull-request-title-pattern": "chore${scope}: release rex-vscode ${version}",
  "changelog-sections": [
    { "type": "feat", "section": "Added" },
    { "type": "fix", "section": "Fixed" },
    { "type": "perf", "section": "Changed" },
    { "type": "refactor", "section": "Changed" },
    { "type": "docs", "section": "Documentation" },
    { "type": "chore", "section": "Other" },
    { "type": "ci", "section": "Other" }
  ],
  "label": "release-extension"
}
