{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rex",
  "version": "1.0.0",
  "identifier": "dev.rex.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../apps/rex-web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build --prefix ../../apps/rex-web",
    "frontendDist": "../../apps/rex-web/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Rex",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
