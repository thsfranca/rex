{
  "mcpAllowlist": [
    "tuiwright:*",
    "github:*",
    "langfuse:*"
  ],
  "autoRun": {
    "allow_instructions": [
      "All tuiwright MCP tools are allowed for Rex TUI design acceptance in fixtures/tui_probe: tui_open, tui_close, tui_send_keys, tui_snapshot, tui_assert, tui_diff, tui_wait_for, tui_resize, tui_record_start, tui_record_stop.",
      "tui_send_keys inputs such as ?, Enter, Tab, and Esc against the isolated tui_probe fixture are bounded test steps, not ad-hoc operator actions."
    ]
  }
}
