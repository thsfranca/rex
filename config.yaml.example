server:
  host: "0.0.0.0"
  port: 8000

models:
  - name: "openai/gpt-4o"
    provider: "openai"
    context_window: 128000
    cost_per_1k_input: 0.005
    cost_per_1k_output: 0.015
    strengths:
      - debugging
      - refactoring
      - code_review
      - generation
    max_latency_ms: 2000
    is_local: false
    api_key: "sk-your-key-here"

  - name: "ollama/llama3"
    provider: "ollama"
    context_window: 8192
    cost_per_1k_input: 0
    cost_per_1k_output: 0
    strengths:
      - completion
      - explanation
    max_latency_ms: 100
    is_local: true
    api_base: "http://localhost:11434"

routing:
  completion_model: "ollama/llama3"
  default_model: "openai/gpt-4o"
