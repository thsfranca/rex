# Copy to repo-root tuiwright.toml (local, untracked). Restart tuiwright MCP after edits.
#
# Launches rex from fixtures/tui_probe/workspace with isolated REX_ROOT so the
# repo-root .rex/config.json does not override probe settings.

[launch]
command = "sh"
args = [
  "-c",
  "cd fixtures/tui_probe/workspace && REX_ROOT=\"$PWD/../rex_root\" exec \"$OLDPWD/target/debug/rex\"",
]

[launch.env]
# Probe uses REX_ROOT + cwd only (see fixtures/tui_probe/README.md). No extra REX_* env vars.
# Optional monochrome acceptance (S8): uncomment for one full matrix run.
# NO_COLOR = "1"

[size]
cols = 120
rows = 40

baseline_dir = ".tuiwright/baselines"

[diff]
# Mask volatile chrome in tui_diff (session ids, semver).
ignore_patterns = ["hs-\\S+", "v\\d+\\.\\d+\\.\\d+"]
quiet_ms = 300

# Stepped motion: send F12 in probe harness to advance animation clock 16ms per key.
# Use tui_send_keys keys="F12" between snapshots for mid-animation baselines.
